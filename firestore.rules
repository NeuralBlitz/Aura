rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }
    
    function uidNotModified() {
      return resource != null && (!('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId);
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) || 
             request.resource.data[field] == null ||
             (request.resource.data[field] is string && 
              request.resource.data[field].size() >= minLen && 
              request.resource.data[field].size() <= maxLen);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser() {
      return hasRequiredFields(['uid', 'createdAt']) &&
             request.resource.data.uid == request.auth.uid &&
             isValidOptionalString('displayName', 0, 100) &&
             isValidOptionalString('photoURL', 0, 500) &&
             (!('email' in request.resource.data) || request.resource.data.email == null || request.resource.data.email is string) &&
             request.resource.data.createdAt is number;
    }

    function isValidThread() {
      return hasRequiredFields(['id', 'userId', 'title', 'updatedAt', 'createdAt']) &&
             request.resource.data.userId == request.auth.uid &&
             isValidOptionalString('title', 1, 200) &&
             (!('modelType' in request.resource.data) || request.resource.data.modelType is string) &&
             request.resource.data.updatedAt is number &&
             request.resource.data.createdAt is number;
    }

    function isValidCustomPrompt() {
      return hasRequiredFields(['id', 'userId', 'name', 'prompt', 'createdAt']) &&
             request.resource.data.userId == request.auth.uid &&
             isValidOptionalString('name', 1, 100) &&
             isValidOptionalString('prompt', 1, 10000) &&
             request.resource.data.createdAt is number;
    }

    function isValidMessage() {
      return hasRequiredFields(['id', 'threadId', 'userId', 'role', 'text', 'timestamp']) &&
             request.resource.data.userId == request.auth.uid &&
             (request.resource.data.role == 'user' || request.resource.data.role == 'model') &&
             request.resource.data.text is string &&
             request.resource.data.text.size() <= 100000 &&
             request.resource.data.timestamp is number;
    }

    function isValidForgeSession() {
      return hasRequiredFields(['id', 'userId', 'code', 'messages', 'plan', 'updatedAt']) &&
             request.resource.data.userId == request.auth.uid &&
             request.resource.data.code is string &&
             request.resource.data.code.size() <= 200000 &&
             request.resource.data.messages is list &&
             request.resource.data.plan is list &&
             request.resource.data.updatedAt is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isOwner(userId) && isValidUser();
      allow update: if isOwner(userId) && isValidUser() && request.resource.data.uid == resource.data.uid;
      allow delete: if isOwner(userId);
    }

    match /threads/{threadId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidThread() && uidUnchanged();
      allow update: if isDocOwner() && isValidThread() && uidNotModified();
      allow delete: if isDocOwner();
      
      match /messages/{messageId} {
        allow read: if isDocOwner();
        allow create: if isAuthenticated() && isValidMessage() && uidUnchanged() && exists(/databases/$(database)/documents/threads/$(threadId)) && get(/databases/$(database)/documents/threads/$(threadId)).data.userId == request.auth.uid;
        allow update: if isDocOwner() && isValidMessage() && uidNotModified();
        allow delete: if isDocOwner();
      }
    }

    match /forge_sessions/{sessionId} {
      allow read, write: if isOwner(sessionId);
    }

    match /custom_prompts/{promptId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidCustomPrompt() && uidUnchanged();
      allow update: if isDocOwner() && isValidCustomPrompt() && uidNotModified();
      allow delete: if isDocOwner();
    }
  }
}
