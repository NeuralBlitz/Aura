{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "ChatThread": {
      "title": "ChatThread",
      "description": "A conversation thread",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "modelType": { "type": "string" },
        "updatedAt": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "userId", "title", "updatedAt", "createdAt"]
    },
    "CustomPrompt": {
      "title": "CustomPrompt",
      "description": "A user-defined custom prompt",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "prompt": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "userId", "name", "prompt", "createdAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message within a chat thread",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "threadId": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "text": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["id", "threadId", "userId", "role", "text", "timestamp"]
    },
    "ForgeSession": {
      "title": "ForgeSession",
      "description": "A spatial substrate forge session including agent state",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "code": { "type": "string" },
        "messages": { "type": "array", "items": { "type": "object" } },
        "plan": { "type": "array", "items": { "type": "object" } },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "userId", "code", "messages", "plan", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/threads/{threadId}": {
      "schema": { "$ref": "#/entities/ChatThread" },
      "description": "User chat threads"
    },
    "/threads/{threadId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/ChatMessage" },
      "description": "Messages in a thread"
    },
    "/forge_sessions/{sessionId}": {
      "schema": { "$ref": "#/entities/ForgeSession" },
      "description": "Forge sessions"
    }
  }
}
